<!DOCTYPE html>
<html lang="bn">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>নহল চৌহমুনি ডিজিটাল সেবা</title>
    
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Anek+Bangla:wght@300;400;600;700&family=Hind+Siliguri:wght@500;600;700&display=swap" rel="stylesheet">
    
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    
    <link href="https://unpkg.com/aos@2.3.1/dist/aos.css" rel="stylesheet">
    
    <script src="https://cdn.tailwindcss.com"></script>

    <style>
        .font-headline { font-family: 'Hind Siliguri', sans-serif; font-weight: 700; }
        .font-body { font-family: 'Anek Bangla', sans-serif; }

        /* সূর্যাস্ত, নদী ও মেঠোপথ বিশিষ্ট চমৎকার গ্রামীণ ল্যান্ডস্কেপ */
        .hero-bg {
            background: linear-gradient(rgba(30, 15, 10, 0.45), rgba(15, 23, 42, 0.85)), 
                        url('https://images.unsplash.com/photo-1600255821058-c4f89958d700?auto=format&fit=crop&w=1920&q=80');
            background-size: cover;
            background-position: center;
            background-attachment: fixed;
        }

        /* মাউস বা হাত রাখলে থ্রিডি ট্রান্সফর্ম ও কালার শিফটিং অ্যানিমেশন */
        .btn-premium {
            transition: all 0.5s cubic-bezier(0.175, 0.885, 0.32, 1.275);
            position: relative;
            overflow: hidden;
            background-size: 200% auto;
        }
        .btn-premium:hover {
            transform: translateY(-6px) scale(1.05) rotate(-0.5deg);
            background-position: right center;
            box-shadow: 0 25px 40px -10px rgba(245, 158, 11, 0.6);
        }
        /* বাটনের ভেতর দিয়ে একটি প্রিমিয়াম লাইট ঝলকানি অ্যানিমেশন */
        .btn-premium::after {
            content: '';
            position: absolute;
            top: -50%; left: -60%; width: 30%; height: 200%;
            background: linear-gradient(90deg, transparent, rgba(255,255,255,0.6), transparent);
            transform: rotate(35deg);
            transition: 0s;
        }
        .btn-premium:hover::after {
            left: 150%;
            transition: 0.8s cubic-bezier(0.4, 0, 0.2, 1);
        }

        /* কার্ডের ওপর আলো ছড়ানোর অ্যানিমেশন (Glow Hover) */
        .card-premium {
            transition: all 0.5s cubic-bezier(0.4, 0, 0.2, 1);
            position: relative;
            z-index: 1;
        }
        .card-premium:hover {
            transform: translateY(-15px) scale(1.03);
            box-shadow: 0 35px 70px -15px rgba(245, 158, 11, 0.15);
        }

        /* টেক্সট পালস এবং সোনালী গ্লোয়িং ইফেক্ট */
        @keyframes gold-pulse {
            0%, 100% { text-shadow: 0 0 20px rgba(251, 191, 36, 0.4); transform: scale(1); }
            50% { text-shadow: 0 0 45px rgba(251, 191, 36, 0.9); color: #fef08a; transform: scale(1.01); }
        }
        .glow-title { animation: gold-pulse 5s infinite ease-in-out; }

        /* কন্টিনিউয়াস ৩D ওয়েভ অ্যানিমেশন */
        @keyframes float-hero {
            0%, 100% { transform: translateY(0px); }
            50% { transform: translateY(-10px); }
        }
        .floating-container { animation: float-hero 6s infinite ease-in-out; }

        /* লাল জরুরি রাডার বাটন অ্যানিমেশন */
        .radar-pulse {
            position: relative;
        }
        .radar-pulse::before {
            content: '';
            position: absolute;
            top: 0; left: 0; width: 100%; height: 100%;
            background: inherit;
            border-radius: inherit;
            z-index: -1;
            animation: radar 2s infinite;
        }
        @keyframes radar {
            0% { transform: scale(1); opacity: 0.8; }
            100% { transform: scale(1.25); opacity: 0; }
        }
    </style>
</head>
<body class="font-body bg-stone-50 text-slate-800 scroll-smooth overflow-x-hidden">

    <header class="sticky top-0 z-50 bg-white/85 backdrop-blur-xl shadow-lg border-b border-orange-100/50">
        <div class="container mx-auto px-6 py-4 flex justify-between items-center">
            <div class="flex items-center space-x-3">
                <div class="bg-gradient-to-tr from-amber-500 to-red-600 text-white p-3 rounded-2xl shadow-xl shadow-orange-100 animate-spin-slow">
                    <i class="fa-solid fa-hands-holding-child text-xl"></i>
                </div>
                <div>
                    <span class="font-headline text-2xl font-bold bg-gradient-to-r from-stone-900 via-amber-800 to-red-700 bg-clip-text text-transparent block leading-none">নহল চৌহমুনি</span>
                    <span class="text-xs text-amber-600 font-extrabold uppercase tracking-widest mt-1.5 block">ডিজিটাল সেবা সংঘটন</span>
                </div>
            </div>
            <a href="#complain" class="btn-premium bg-gradient-to-r from-emerald-500 to-teal-600 text-white font-headline px-8 py-3 rounded-xl shadow-md hidden md:block">
                <i class="fa-solid fa-headset mr-2"></i> সেবা নিন
            </a>
        </div>
    </header>

    <section class="hero-bg min-h-[95vh] flex items-center justify-center text-center text-white px-4 relative">
        <div class="max-w-4xl mx-auto space-y-8 floating-container">
            <span class="bg-gradient-to-r from-amber-500/20 to-red-500/20 text-amber-300 border border-amber-500/40 px-6 py-2.5 rounded-full text-sm font-semibold tracking-wide inline-block backdrop-blur-md shadow-inner">
                <i class="fa-solid fa-sun mr-2 text-amber-400 animate-spin-slow"></i> একটি সুন্দর, নিরাপদ ও আধুনিক সমাজ গড়ার প্রত্যয়ে
            </span>
            <h1 class="font-headline text-5xl md:text-7xl lg:text-8xl font-bold leading-tight tracking-tight glow-title transition-all duration-500">
                নহল চৌহমুনি <br><span class="text-transparent bg-clip-text bg-gradient-to-r from-amber-400 via-orange-400 to-yellow-500">ডিজিটাল সেবা</span>
            </h1>
            <p class="text-lg md:text-2xl text-stone-200 max-w-3xl mx-auto leading-relaxed font-light">
                আমাদের গ্রাম হবে মাদকমুক্ত ও সম্পূর্ণ নিরাপদ। যেকোনো অন্যায়, চাঁদাবাজি এবং জরুরি প্রয়োজনে ডিজিটাল সেবা সংঘটন সর্বদা আপনার পাশে।
            </p>
            <div class="pt-6 flex flex-wrap justify-center gap-6">
                <a href="#emergency" class="btn-premium radar-pulse bg-gradient-to-r from-red-600 to-rose-700 text-white font-headline text-lg px-9 py-5 rounded-2xl shadow-xl flex items-center gap-3">
                    <i class="fa-solid fa-phone-flip animate-shake"></i> জরুরি সরকারি নাম্বার
                </a>
                <a href="#complain" class="btn-premium bg-gradient-to-r from-amber-500 via-orange-500 to-amber-600 text-slate-950 font-headline text-lg px-9 py-5 rounded-2xl shadow-xl flex items-center gap-3 font-bold">
                    <i class="fa-solid fa-bullhorn"></i> ডিজিটাল অভিযোগ কেন্দ্র
                </a>
            </div>
        </div>
    </section>

    <section class="py-16 bg-gradient-to-r from-red-700 via-orange-600 to-amber-600 text-white text-center shadow-2xl relative z-10 overflow-hidden">
        <div class="container mx-auto px-4 max-w-4xl space-y-2">
            <h2 class="font-headline text-3xl md:text-5xl font-bold tracking-wide leading-tight text-yellow-300" data-aos="zoom-in" data-aos-duration="1000">
                <i class="fa-solid fa-ban mr-3 text-white"></i> মাদক মুক্ত সমাজ চাই, অপরাধীদের ঠাঁই নাই!
            </h2>
            <p class="text-orange-100 text-base md:text-lg font-medium" data-aos="fade-up" data-aos-delay="300">মাদক কারবারি, সন্ত্রাসী ও চাঁদাবাজদের বিরুদ্ধে আজই সোচ্চার হোন।</p>
        </div>
    </section>

    <section id="emergency" class="py-32 container mx-auto px-6 overflow-hidden">
        <div class="text-center max-w-2xl mx-auto mb-20" data-aos="fade-up">
            <h2 class="font-headline text-4xl md:text-5xl font-bold text-stone-900 mb-4">জরুরি সরকারি সেবা সমূহ</h2>
            <p class="text-slate-500 text-lg">যেকোনো মুহূর্তে তাৎক্ষণিক সাহায্যের জন্য নিচের বাটনগুলোতে সরাসরি ক্লিক করে কল করুন।</p>
            <div class="h-1.5 w-24 bg-gradient-to-r from-amber-500 to-red-600 mx-auto mt-4 rounded-full"></div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-10 max-w-6xl mx-auto">
            <div class="card-premium bg-white p-9 rounded-[2rem] border border-stone-100 flex flex-col justify-between shadow-xl shadow-stone-100/50 group" data-aos="fade-right" data-aos-duration="1000">
                <div>
                    <div class="w-16 h-16 bg-blue-50 text-blue-600 rounded-2xl flex items-center justify-center mb-6 text-3xl shadow-inner group-hover:bg-blue-600 group-hover:text-white group-hover:rotate-12 transition-all duration-500">
                        <i class="fa-solid fa-shield-halved"></i>
                    </div>
                    <h3 class="font-headline text-2xl font-bold text-stone-800 mb-3">বাংলাদেশ পুলিশ</h3>
                    <p class="text-slate-500 mb-8 text-sm leading-relaxed">আইনশৃঙ্খলা রক্ষা এবং যেকোনো সন্ত্রাসী বা অপরাধমূলক কর্মকাণ্ডের বিরুদ্ধে দ্রুত আইনি ব্যবস্থা নিতে।</p>
                </div>
                <a href="tel:999" class="btn-premium bg-gradient-to-r from-blue-600 to-indigo-700 text-white font-headline py-4 rounded-xl text-center font-bold shadow-md text-lg">
                    <i class="fa-solid fa-phone mr-2"></i> কল করুন (৯৯৯)
                </a>
            </div>

            <div class="card-premium bg-white p-9 rounded-[2rem] border border-stone-100 flex flex-col justify-between shadow-xl shadow-stone-100/50 group" data-aos="fade-up" data-aos-duration="1000" data-aos-delay="200">
                <div>
                    <div class="w-16 h-16 bg-red-50 text-red-600 rounded-2xl flex items-center justify-center mb-6 text-3xl shadow-inner group-hover:bg-red-600 group-hover:text-white group-hover:rotate-12 transition-all duration-500">
                        <i class="fa-solid fa-fire-extinguisher"></i>
                    </div>
                    <h3 class="font-headline text-2xl font-bold text-stone-800 mb-3">ফায়ার সার্ভিস</h3>
                    <p class="text-slate-500 mb-8 text-sm leading-relaxed">হঠাৎ অগ্নিকাণ্ড, মারাত্মক সড়ক দুর্ঘটনা অথবা যেকোনো দুর্যোগপূর্ণ উদ্ধারকাজে সহায়তার জন্য।</p>
                </div>
                <a href="tel:16163" class="btn-premium bg-gradient-to-r from-red-600 to-rose-700 text-white font-headline py-4 rounded-xl text-center font-bold shadow-md text-lg">
                    <i class="fa-solid fa-phone mr-2"></i> কল করুন (১৬১৬৩)
                </a>
            </div>

            <div class="card-premium bg-white p-9 rounded-[2rem] border border-stone-100 flex flex-col justify-between shadow-xl shadow-stone-100/50 group" data-aos="fade-left" data-aos-duration="1000" data-aos-delay="400">
                <div>
                    <div class="w-16 h-16 bg-emerald-50 text-emerald-600 rounded-2xl flex items-center justify-center mb-6 text-3xl shadow-inner group-hover:bg-emerald-600 group-hover:text-white group-hover:rotate-12 transition-all duration-500">
                        <i class="fa-solid fa-truck-medical"></i>
                    </div>
                    <h3 class="font-headline text-2xl font-bold text-stone-800 mb-3">জরুরি অ্যাম্বুলেন্স</h3>
                    <p class="text-slate-500 mb-8 text-sm leading-relaxed">যেকোনো মেডিকেল ইমার্জেন্সি অথবা গুরুতর অসুস্থ রোগীকে দ্রুততম সময়ে হাসপাতালে স্থানান্তর করতে।</p>
                </div>
                <a href="tel:999" class="btn-premium bg-gradient-to-r from-emerald-600 to-teal-700 text-white font-headline py-4 rounded-xl text-center font-bold shadow-md text-lg">
                    <i class="fa-solid fa-phone mr-2"></i> কল করুন (৯৯৯)
                </a>
            </div>
        </div>
    </section>

    <section id="complain" class="py-28 bg-gradient-to-b from-stone-100 via-stone-200/40 to-stone-100 border-t border-stone-200 overflow-hidden">
        <div class="container mx-auto px-6 max-w-5xl" data-aos="zoom-in-up" data-aos-duration="1200">
            <div class="bg-white rounded-[2.5rem] shadow-2xl overflow-hidden grid grid-cols-1 md:grid-cols-5 border border-stone-100">
                
                <div class="md:col-span-2 bg-gradient-to-b from-stone-950 via-zinc-900 to-neutral-950 text-white p-11 flex flex-col justify-between relative">
                    <div class="space-y-6">
                        <div class="bg-amber-500/10 text-amber-400 p-4 rounded-2xl inline-block border border-amber-500/25 animate-bounce">
                            <i class="fa-solid fa-user-secret text-3xl"></i>
                        </div>
                        <h3 class="font-headline text-3xl font-bold text-amber-400 tracking-wide">শতভাগ গোপন অভিযোগ কেন্দ্র</h3>
                        <p class="text-stone-400 text-sm leading-relaxed font-light">
                            আপনার নাম বা পরিচয় প্রকাশ না করেই আপনার এলাকার মাদক কারবারি, সন্ত্রাসী কর্মকাণ্ড বা চাঁদাবাজদের বিরুদ্ধে সরাসরি অভিযোগ জমা দিন।
                        </p>
                    </div>
                    <div class="pt-8 border-t border-stone-800 space-y-4 text-sm text-stone-300">
                        <div class="flex items-center gap-3"><i class="fa-solid fa-shield-halved text-emerald-500 text-base"></i> সম্পূর্ণ তথ্য এনক্রিপ্টেড ও সুরক্ষিত</div>
                        <div class="flex items-center gap-3"><i class="fa-solid fa-bolt text-amber-500 text-base"></i> সরাসরি কার্যকরী ব্যবস্থা গ্রহণ</div>
                    </div>
                </div>

                <form class="md:col-span-3 p-11 space-y-6" onsubmit="alert('আপনার অভিযোগটি অত্যন্ত গোপনীয়তার সাথে সফলভাবে জমা নেওয়া হয়েছে। ধন্যবাদ!'); return false;">
                    <div>
                        <label class="block text-stone-700 font-bold mb-2.5 text-sm uppercase tracking-wider">অভিযোগের ধরণ</label>
                        <select class="w-full border border-stone-200 rounded-xl px-4 py-4 bg-stone-50 focus:outline-none focus:border-orange-500 focus:bg-white transition-all duration-300 font-body text-stone-800" required>
                            <option value="">নির্বাচন করুন...</option>
                            <option value="madiok">মাদক বিক্রয়, সেবন ও চোরাচালান</option>
                            <option value="sontros">সন্ত্রাসী কর্মকাণ্ড ও বিশৃঙ্খলা সৃষ্টি</option>
                            <option value="chadabaj">জোরপূর্বক চাঁদাবাজি ও হুমকি প্রদান</option>
                            <option value="অন্যান্য">অন্যান্য সামাজিক অপরাধমূলক কাজ</option>
                        </select>
                    </div>

                    <div>
                        <label class="block text-stone-700 font-bold mb-2.5 text-sm uppercase tracking-wider">বিস্তারিত বিবরণ ও অপরাধের স্থান</label>
                        <textarea rows="4" class="w-full border border-stone-200 rounded-xl px-4 py-4 bg-stone-50 focus:outline-none focus:border-orange-500 focus:bg-white transition-all duration-300 font-body text-stone-800" placeholder="নির্দিষ্ট স্থান, ঘটনার সময় এবং অভিযুক্ত ব্যক্তির নাম (যদি জানা থাকে) স্পষ্টভাবে লিখুন..." required></textarea>
                    </div>

                    <div class="bg-amber-50 border border-amber-200 text-amber-950 rounded-2xl p-4 text-xs flex items-start gap-3">
                        <i class="fa-solid fa-circle-info text-base text-amber-600 mt-0.5"></i>
                        <span class="leading-relaxed">আপনার নিরাপত্তার কথা চিন্তা করে এখানে কোনো নাম বা ফোন নাম্বারের অপশন রাখা হয়নি। তাই নির্ভয়ে সত্যি তথ্যটি দিয়ে সমাজকে সুন্দর করতে সাহায্য করুন।</span>
                    </div>

                    <button type="submit" class="btn-premium w-full bg-gradient-to-r from-amber-500 to-orange-600 text-slate-950 font-headline font-extrabold py-4.5 rounded-xl shadow-lg text-center text-lg uppercase tracking-wide">
                        <i class="fa-solid fa-paper-plane mr-2"></i> অভিযোগ জমা দিন
                    </button>
                </form>

            </div>
        </div>
    </section>

    <footer class="bg-slate-950 text-stone-500 py-16 text-center border-t border-slate-900">
        <div class="container mx-auto px-6 space-y-4">
            <p class="font-headline text-2xl text-white font-bold" data-aos="fade-up">নহল চৌহমুনি ডিজিটাল সেবা সংঘটন</p>
            <p class="text-sm max-w-md mx-auto leading-relaxed text-stone-400" data-aos="fade-up" data-aos-delay="200">একটি অপরাধমুক্ত, শান্ত ও সুন্দর সমাজ বিনির্মাণে আমরা সর্বদা ডিজিটাল প্রযুক্তির মাধ্যমে জনগণের সেবায় নিয়োজিত।</p>
            <div class="h-px w-20 bg-gradient-to-r from-amber-500 to-red-600 mx-auto my-6" data-aos="zoom-in"></div>
            <p class="text-xs tracking-widest text-stone-600">&copy; ২০২৬ সর্বস্বত্ব সংরক্ষিত।</p>
        </div>
    </footer>

    <script src="https://unpkg.com/aos@2.3.1/dist/aos.js"></script>
    <script>
        // AOS অ্যানিমেশন লাইব্রেরি অ্যাক্টিভেট করা হলো
        AOS.init({
            once: false, // স্ক্রল করার সময় বারবার অ্যানিমেশন হবে
            mirror: true
        });
    </script>

</body>
</html>

